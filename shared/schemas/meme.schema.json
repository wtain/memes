{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "meme.schema.json",
  "title": "Meme",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "imageUrl": { "type": "string", "format": "url" },
    "originalFileName": { "type": "string" },
    "text": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "./memetag.schema.json"
      }
    }
  },
  "required": ["id", "imageUrl"]
}